# Data (raw data should not be committed)
raw/
*.csv
*.dta
*.sas7bdat
*.parquet
*.feather
*.xlsx
*.xls

# But allow template and reference files
!latex_template/**
!*.bib
!*.bst

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Credentials
.env
*.pgpass
credentials*

# Large output files
output/figures/*.png
output/figures/*.pdf
output/tables/*.tex
