# =============================================================================
# Credentials and API Keys
# Copy this file to .env and fill in your values
# =============================================================================

# WRDS (Wharton Research Data Services)
# Access CRSP, Compustat, IBES, TRACE, and more
# Your institutional WRDS username (credentials in ~/.pgpass)
# Setup: https://wrds-www.wharton.upenn.edu/
WRDS_USERNAME=

# FRED (Federal Reserve Economic Data)
# 800K+ economic series: GDP, CPI, interest rates, housing, employment
# Register: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# BLS (Bureau of Labor Statistics)
# CPI, employment, wages, JOLTS, productivity
# Register: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# Census Bureau
# ACS demographics, income, housing characteristics, population
# Register: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# BEA (Bureau of Economic Analysis)
# GDP, personal income, regional accounts, input-output tables
# Register: https://apps.bea.gov/API/signup/
BEA_API_KEY=
